<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Eğer istek public klasörüne yapılmıyorsa, public klasörüne yönlendir
    RewriteCond %{REQUEST_URI} !^/t-r-takip/public/
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]

    # Güvenlik: .env ve yapılandırma dosyalarına doğrudan erişimi engelle
    RewriteRule ^\.env - [F,L,NC]
    RewriteRule ^composer\.(json|lock)$ - [F,L,NC]
    RewriteRule ^package(-lock)?\.json$ - [F,L,NC]
</IfModule>